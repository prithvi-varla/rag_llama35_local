{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Query Script",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_query.py",
      "args": [
        "--settings", "config/settings.yaml",
        "--mode", "hybrid",
        "--query", "Why combine BM25 with dense retrieval?"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}